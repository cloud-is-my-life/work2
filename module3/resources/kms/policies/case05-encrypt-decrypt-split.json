{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EncryptOnly",
      "Effect": "Allow",
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:GenerateDataKeyWithoutPlaintext",
        "kms:DescribeKey"
      ],
      "Resource": "arn:aws:kms:AWS_REGION:ACCOUNT_ID:key/KEY_ID"
    }
  ]
}
