{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyInlinePolicyOnUsers",
      "Effect": "Deny",
      "Action": [
        "iam:PutUserPolicy",
        "iam:DeleteUserPolicy"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyInlinePolicyOnRoles",
      "Effect": "Deny",
      "Action": [
        "iam:PutRolePolicy",
        "iam:DeleteRolePolicy"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyInlinePolicyOnGroups",
      "Effect": "Deny",
      "Action": [
        "iam:PutGroupPolicy",
        "iam:DeleteGroupPolicy"
      ],
      "Resource": "*"
    }
  ]
}
