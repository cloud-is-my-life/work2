{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCreateSecretWithNamePattern",
      "Effect": "Allow",
      "Action": "secretsmanager:CreateSecret",
      "Resource": "*",
      "Condition": {
        "StringLike": {
          "secretsmanager:Name": "prod/*"
        }
      }
    },
    {
      "Sid": "DenyCreateSecretOutsidePattern",
      "Effect": "Deny",
      "Action": "secretsmanager:CreateSecret",
      "Resource": "*",
      "Condition": {
        "StringNotLike": {
          "secretsmanager:Name": "prod/*"
        }
      }
    },
    {
      "Sid": "AllowReadWithinPattern",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret",
        "secretsmanager:ListSecretVersionIds"
      ],
      "Resource": "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:prod/*"
    },
    {
      "Sid": "AllowListSecrets",
      "Effect": "Allow",
      "Action": "secretsmanager:ListSecrets",
      "Resource": "*"
    }
  ]
}
