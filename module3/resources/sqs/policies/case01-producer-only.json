{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSendOnly",
      "Effect": "Allow",
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:AWS_REGION:ACCOUNT_ID:QUEUE_NAME"
    },
    {
      "Sid": "AllowGetQueueUrl",
      "Effect": "Allow",
      "Action": "sqs:GetQueueUrl",
      "Resource": "arn:aws:sqs:AWS_REGION:ACCOUNT_ID:QUEUE_NAME"
    }
  ]
}
