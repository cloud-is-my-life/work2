{
  "_comment": "Queue Policy (sqs:SetQueueAttributesыбЬ ьаБьЪй)",
  "Version": "2012-10-17",
  "Id": "SNSToSQSPolicy",
  "Statement": [
    {
      "Sid": "AllowSNSToSend",
      "Effect": "Allow",
      "Principal": {
        "Service": "sns.amazonaws.com"
      },
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:AWS_REGION:ACCOUNT_ID:QUEUE_NAME",
      "Condition": {
        "ArnLike": {
          "aws:SourceArn": "arn:aws:sns:AWS_REGION:ACCOUNT_ID:TOPIC_NAME"
        }
      }
    }
  ]
}
