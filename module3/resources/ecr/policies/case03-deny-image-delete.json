{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyImageDelete",
      "Effect": "Deny",
      "Action": "ecr:BatchDeleteImage",
      "Resource": "arn:aws:ecr:AWS_REGION:ACCOUNT_ID:repository/*"
    },
    {
      "Sid": "DenyRepoDelete",
      "Effect": "Deny",
      "Action": "ecr:DeleteRepository",
      "Resource": "arn:aws:ecr:AWS_REGION:ACCOUNT_ID:repository/*"
    }
  ]
}
