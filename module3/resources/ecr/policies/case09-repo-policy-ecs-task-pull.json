{
  "_comment": "Repository Policy — ECS Task 실행 역할(ecsTaskExecutionRole)에 Pull 허용. IAM Policy가 아닌 리포지토리 Resource-based Policy로 설정.",
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowECSTaskExecutionRolePull",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::ACCOUNT_ID:role/ecsTaskExecutionRole"
      },
      "Action": [
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:BatchCheckLayerAvailability",
        "ecr:DescribeImages",
        "ecr:ListImages"
      ]
    },
    {
      "Sid": "AllowECSServiceLinkedRole",
      "Effect": "Allow",
      "Principal": {
        "Service": "ecs-tasks.amazonaws.com"
      },
      "Action": [
        "ecr:GetDownloadUrlForLayer",
        "ecr:BatchGetImage",
        "ecr:BatchCheckLayerAvailability"
      ],
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "ACCOUNT_ID"
        }
      }
    }
  ]
}
