{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowGeneralTagging",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateTags",
        "ec2:DeleteTags"
      ],
      "Resource": "arn:aws:ec2:AWS_REGION:ACCOUNT_ID:*/*",
      "Condition": {
        "ForAllValues:StringNotEquals": {
          "aws:TagKeys": [
            "Environment",
            "CostCenter",
            "Owner"
          ]
        }
      }
    },
    {
      "Sid": "DenyModifyProtectedTagKeys",
      "Effect": "Deny",
      "Action": [
        "ec2:CreateTags",
        "ec2:DeleteTags"
      ],
      "Resource": "arn:aws:ec2:AWS_REGION:ACCOUNT_ID:*/*",
      "Condition": {
        "ForAnyValue:StringEquals": {
          "aws:TagKeys": [
            "Environment",
            "CostCenter",
            "Owner"
          ]
        }
      }
    },
    {
      "Sid": "AllowDescribe",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeTags"
      ],
      "Resource": "*"
    }
  ]
}
