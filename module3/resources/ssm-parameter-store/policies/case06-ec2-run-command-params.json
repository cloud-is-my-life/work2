{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowEC2RunCommandParamRead",
      "Effect": "Allow",
      "Action": [
        "ssm:GetParameter",
        "ssm:GetParameters"
      ],
      "Resource": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/ec2/run-command/*"
    },
    {
      "Sid": "AllowDescribeParameters",
      "Effect": "Allow",
      "Action": "ssm:DescribeParameters",
      "Resource": "*"
    },
    {
      "Sid": "AllowSendCommand",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand",
        "ssm:ListCommands",
        "ssm:ListCommandInvocations",
        "ssm:GetCommandInvocation"
      ],
      "Resource": [
        "arn:aws:ssm:REGION:*:document/AWS-RunShellScript",
        "arn:aws:ssm:REGION:*:document/AWS-RunPowerShellScript",
        "arn:aws:ec2:REGION:ACCOUNT_ID:instance/*"
      ]
    },
    {
      "Sid": "DenyRunCommandParamWrite",
      "Effect": "Deny",
      "Action": [
        "ssm:PutParameter",
        "ssm:DeleteParameter",
        "ssm:DeleteParameters"
      ],
      "Resource": "arn:aws:ssm:REGION:ACCOUNT_ID:parameter/ec2/run-command/*"
    }
  ]
}
