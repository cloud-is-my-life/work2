{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSubscribeHTTPSOnly",
      "Effect": "Allow",
      "Action": "sns:Subscribe",
      "Resource": "arn:aws:sns:AWS_REGION:ACCOUNT_ID:TOPIC_NAME",
      "Condition": {
        "StringEquals": {
          "sns:Protocol": "https"
        }
      }
    },
    {
      "Sid": "DenySubscribeNonHTTPS",
      "Effect": "Deny",
      "Action": "sns:Subscribe",
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "sns:Protocol": "https"
        }
      }
    },
    {
      "Sid": "AllowUnsubscribe",
      "Effect": "Allow",
      "Action": "sns:Unsubscribe",
      "Resource": "arn:aws:sns:AWS_REGION:ACCOUNT_ID:TOPIC_NAME:*"
    }
  ]
}
