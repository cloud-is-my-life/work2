{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowInsightsQueryOnly",
      "Effect": "Allow",
      "Action": [
        "logs:StartQuery",
        "logs:StopQuery",
        "logs:GetQueryResults",
        "logs:DescribeQueries"
      ],
      "Resource": "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:LOG_GROUP_NAME:*"
    },
    {
      "Sid": "AllowDescribeLogGroups",
      "Effect": "Allow",
      "Action": "logs:DescribeLogGroups",
      "Resource": "*"
    }
  ]
}
