{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowCreateLogGroup",
      "Effect": "Allow",
      "Action": "logs:CreateLogGroup",
      "Resource": "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:/aws/lambda/FUNCTION_NAME"
    },
    {
      "Sid": "AllowWriteLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:/aws/lambda/FUNCTION_NAME:*"
    }
  ]
}
