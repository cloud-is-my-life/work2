{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowWriteToProdLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup"
      ],
      "Resource": "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:/app/prod/*"
    },
    {
      "Sid": "AllowWriteStreamsAndEvents",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:/app/prod/*:*"
    },
    {
      "Sid": "DenyWriteToOtherPaths",
      "Effect": "Deny",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": [
        "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:/app/dev/*:*",
        "arn:aws:logs:AWS_REGION:ACCOUNT_ID:log-group:/app/staging/*:*"
      ]
    }
  ]
}
