{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListReportsPrefix",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::DATA_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["reports/*"]
        }
      }
    },
    {
      "Sid": "AllowReadReportsObjects",
      "Effect": "Allow",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::DATA_BUCKET/reports/*"
    },
    {
      "Sid": "DenyDeleteReportsObjects",
      "Effect": "Deny",
      "Action": "s3:DeleteObject",
      "Resource": "arn:aws:s3:::DATA_BUCKET/reports/*"
    },
    {
      "Sid": "DenyNonTLS",
      "Effect": "Deny",
      "Action": "s3:*",
      "Resource": [
        "arn:aws:s3:::DATA_BUCKET",
        "arn:aws:s3:::DATA_BUCKET/*"
      ],
      "Condition": {
        "Bool": {
          "aws:SecureTransport": "false"
        }
      }
    }
  ]
}
