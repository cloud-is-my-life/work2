{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSNSTrigger",
      "Effect": "Allow",
      "Principal": {
        "Service": "sns.amazonaws.com"
      },
      "Action": "lambda:InvokeFunction",
      "Resource": "arn:aws:lambda:AWS_REGION:ACCOUNT_ID:function:FUNCTION_NAME",
      "Condition": {
        "ArnLike": {
          "aws:SourceArn": "arn:aws:sns:AWS_REGION:ACCOUNT_ID:TOPIC_NAME"
        },
        "StringEquals": {
          "aws:SourceAccount": "ACCOUNT_ID"
        }
      }
    }
  ]
}
