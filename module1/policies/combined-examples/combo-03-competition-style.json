{
    "Version": "2012-10-17",
    "Id": "competition-style-policy",
    "Statement": [
        {
            "Sid": "AllowAppInstancesAccessToEFS",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::<ACCOUNT_ID>:role/wsi-ec2-efs-role"
            },
            "Action": [
                "elasticfilesystem:ClientMount",
                "elasticfilesystem:ClientWrite"
            ],
            "Condition": {
                "Bool": {
                    "aws:SecureTransport": "true"
                },
                "StringEquals": {
                    "aws:PrincipalTag/AppRole": "wsi-app"
                },
                "IpAddress": {
                    "aws:SourceIp": [
                        "10.128.128.0/24",
                        "10.128.144.0/24"
                    ]
                },
                "DateGreaterThan": {
                    "aws:CurrentTime": "2026-06-01T00:00:00Z"
                },
                "DateLessThan": {
                    "aws:CurrentTime": "2026-06-30T23:59:59Z"
                }
            }
        },
        {
            "Sid": "DenyRootAccess",
            "Effect": "Deny",
            "Principal": { "AWS": "*" },
            "Action": "elasticfilesystem:ClientRootAccess",
            "Condition": {}
        },
        {
            "Sid": "DenyBastionAccess",
            "Effect": "Deny",
            "Principal": "*",
            "Action": "*",
            "Condition": {
                "IpAddress": {
                    "aws:SourceIp": "10.128.0.0/24"
                }
            }
        },
        {
            "Sid": "EnforceTLS",
            "Effect": "Deny",
            "Principal": { "AWS": "*" },
            "Action": "*",
            "Condition": {
                "Bool": {
                    "aws:SecureTransport": "false"
                }
            }
        }
    ]
}
