{
    "Version": "2012-10-17",
    "Id": "enforce-tls-policy",
    "Statement": [
        {
            "Sid": "DenyNonTLS",
            "Effect": "Deny",
            "Principal": { "AWS": "*" },
            "Action": "*",
            "Condition": {
                "Bool": {
                    "aws:SecureTransport": "false"
                }
            }
        }
    ]
}
