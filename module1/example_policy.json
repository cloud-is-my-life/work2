{
    "Version": "2012-10-17",
    "Id": "efs-policy-example",
    "Statement": [
        {
            "Sid": "efs-statement-bb66e68c-64a4-443f-bb9c-795190cebc49",
            "Effect": "Allow",
            "Principal": {
                "AWS": "*"
            },
            "Action": [
                "<remove it if root access is denied> elasticfilesystem:ClientRootAccess",
                "<remove it if readonly access is default> elasticfilesystem:ClientWrite",
                "<remove it if anonymous access is denied> elasticfilesystem:ClientMount"
            ],
            "Condition": {
                "Bool": {
                    "elasticfilesystem:AccessedViaMountTarget": "true"
                }
            }
        },
        {
            "Sid": "Deny-If-TLS-is-Not-Applied",
            "Effect": "Deny",
            "Principal": {
                "AWS": "*"
            },
            "Action": "*",
            "Condition": {
                "Bool": {
                    "aws:SecureTransport": "false"
                }
            }
        },
        {
            "Sid": "Deny-for-specific-ipaddr",
            "Effect": "Deny",
            "Principal": "*",
            "Action": "*",
            "Resource": "*",
            "Condition": {
              "IpAddress": {
                "aws:SourceIp": "<enter CIDR like 10.128.0.199/32>"
              }
            }
        },
        {
            "Sid": "Allow-Access-from-Specific-ResourceARN-ex-IAMRole-IAMUser-etc",
            "Effect": "Allow",
            "Principal": {
                "AWS": "<example arn:aws:iam::156041424727:role/juanyrole>"
            },
            "Action": [
                "elasticfilesystem:ClientMount"
            ]
        }
    ]
}